+++ BASIC_TESTS
!C! 0
!I! 0
>>> 1

"Basic string operations: concatenateWith:, length, asString"
class Main : Object {
    run [|
        a := 'Hello'.
        b := ' World'.
        c := a concatenateWith: b.
        _ := c print.
        len := c length.
        _ := (len asString) print.
    ]
}
