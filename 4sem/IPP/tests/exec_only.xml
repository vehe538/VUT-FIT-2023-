<?xml version="1.0" encoding="UTF-8"?>
<program language="SOL26" description="Basic hello world - prints a string">
  <class name="Main" parent="Object">
    <method selector="run">
      <block arity="0">
        <assign order="1">
          <var name="_"/>
          <expr>
            <send selector="print">
              <expr>
                <literal class="String" value="Hello, World!"/>
              </expr>
            </send>
          </expr>
        </assign>
      </block>
    </method>
  </class>
</program>
