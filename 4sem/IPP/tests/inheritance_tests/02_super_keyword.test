+++ INHERITANCE_TESTS
!C! 0
!I! 0
>>> 3

"From spec section 1.2.8 - super keyword usage"
class A : Object {
    m: [ :x |
        _ := x print.
    ]
    r [|
        _ := self print.
    ]
}

class B : A {
    m: [ :x |
        _ := super m: 'ahoj'.
        _ := x print.
    ]
}

class C : B {
    u [|
        _ := self m: super.
    ]
    print [|
        _ := 'bar' print.
    ]
}

class Main : Object {
    run [|
        c := C new.
        _ := c m: 'foo'.
        _ := c u.
        _ := c r.
    ]
}
